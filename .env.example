# ============================================================
# HealthMonitoringAssistant 生产环境配置模板
# 复制为 .env 并填写真实值后部署
# cp .env.example .env
# ============================================================

# ------------------ 数据库配置（Docker 内网使用） ------------------
DB_USER=healthuser
DB_PASSWORD=ChangeThisStrongPassword123!
DB_NAME=health_monitoring

# 后端自动拼接 DATABASE_URL，无需手动修改
# DATABASE_URL=postgresql://healthuser:密码@postgres:5432/health_monitoring?schema=public

# ------------------ Redis 配置 ------------------
REDIS_URL=redis://redis:6379

# ------------------ JWT 配置（必须修改！） ------------------
JWT_SECRET=your-super-secret-jwt-key-change-in-production-now
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ------------------ 服务器配置 ------------------
PORT=3001
NODE_ENV=production

# ------------------ OCR 服务配置（百度AI）------------------
# 没有则不填，OCR 功能将不可用
BAIDU_OCR_APP_ID=
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# ------------------ 文件上传配置 ------------------
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ------------------ 日志配置 ------------------
LOG_LEVEL=info

# ------------------ 阿里云短信服务配置 ------------------
# 没有则不填，短信验证码功能将不可用（注册/登录需要手动输入固定码测试）
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=肾健康助手
SMS_ENDPOINT=https://dypnsapi.aliyuncs.com
SMS_TEMPLATE_CODE_VERIFICATION=
SMS_VERIFICATION_VALID_TIME=300
SMS_VERIFICATION_CODE_LENGTH=6
SMS_VERIFICATION_INTERVAL=60

# ------------------ Web Push 配置 ------------------
# 生成命令: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
