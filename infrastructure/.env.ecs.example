# ============================================
# ECS生产环境配置模板（无短信功能）
# ============================================
# 重要提示:
# 1. 复制此文件为 .env 并填写实际值
# 2. 此文件包含敏感信息，请勿提交到 Git
# 3. 生产环境密钥应使用随机生成的强密码
# ============================================

# ----------------------------------------
# 基础配置
# ----------------------------------------
NODE_ENV=production
PORT=3000

# ----------------------------------------
# 数据库配置 (PostgreSQL - 本地容器)
# 如需使用RDS，请替换为实际连接地址
# ----------------------------------------
POSTGRES_USER=health_prod
POSTGRES_PASSWORD=your-strong-password-here
POSTGRES_DB=health_monitoring_prod
# 使用本地postgres容器
DATABASE_URL=postgresql://health_prod:your-strong-password-here@postgres:5432/health_monitoring_prod
# 或使用阿里云RDS:
# DATABASE_URL=postgresql://user:password@your-rds-endpoint.rds.aliyuncs.com:5432/health_monitoring

# ----------------------------------------
# Redis 配置 (本地容器)
# 如需使用云Redis，请替换为实际连接地址
# ----------------------------------------
REDIS_PASSWORD=your-redis-password-here
# 使用本地redis容器
REDIS_URL=redis://:your-redis-password-here@redis:6379
# 或使用阿里云Redis:
# REDIS_URL=redis://:password@your-redis-endpoint.redis.rds.aliyuncs.com:6379

# ----------------------------------------
# JWT 配置
# ----------------------------------------
# 生产环境必须使用随机生成的强密钥
# 生成命令: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-min-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-min-32-characters-long
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ----------------------------------------
# 数据加密密钥
# ----------------------------------------
# 用于加密敏感医疗数据
# 生成命令: openssl rand -base64 32
ENCRYPTION_KEY=your-encryption-key-32-chars

# ----------------------------------------
# 百度 OCR 配置（已配置好）
# ----------------------------------------
BAIDU_OCR_API_KEY=your-baidu-api-key
BAIDU_OCR_SECRET_KEY=your-baidu-secret-key

# ----------------------------------------
# 短信服务配置（已禁用）
# ----------------------------------------
SMS_ENABLED=false
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=

# ----------------------------------------
# 文件上传配置
# ----------------------------------------
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ----------------------------------------
# 日志配置
# ----------------------------------------
LOG_LEVEL=info

# ----------------------------------------
# Worker 配置
# ----------------------------------------
ENABLE_REMINDER_WORKER=true
ENABLE_SMS_NOTIFICATION=false
