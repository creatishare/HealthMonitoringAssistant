# ============================================
# 生产环境配置模板
# ============================================
# 重要提示:
# 1. 此文件包含敏感信息，请勿提交到 Git
# 2. 确保此文件已添加到 .gitignore
# 3. 生产环境密钥应使用随机生成的强密码
# ============================================

# ----------------------------------------
# 基础配置
# ----------------------------------------
NODE_ENV=production
PORT=3000

# ----------------------------------------
# 数据库配置 (PostgreSQL)
# ----------------------------------------
# 使用云数据库 RDS 时，替换为实际连接地址
POSTGRES_USER=health_prod
POSTGRES_DB=health_monitoring_prod
# 从环境变量或密钥管理服务获取密码
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
DATABASE_URL=${DATABASE_URL}

# ----------------------------------------
# Redis 配置
# ----------------------------------------
# 使用云 Redis 服务时，替换为实际连接地址
REDIS_PASSWORD=${REDIS_PASSWORD}
REDIS_URL=${REDIS_URL}

# ----------------------------------------
# JWT 配置
# ----------------------------------------
# 生产环境必须使用随机生成的强密钥
# 生成命令: openssl rand -base64 32
JWT_SECRET=${JWT_SECRET}
JWT_REFRESH_SECRET=${JWT_REFRESH_SECRET}
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ----------------------------------------
# 数据加密密钥
# ----------------------------------------
# 用于加密敏感医疗数据
# 生成命令: openssl rand -base64 32
ENCRYPTION_KEY=${ENCRYPTION_KEY}

# ----------------------------------------
# 百度 OCR 配置
# ----------------------------------------
BAIDU_OCR_API_KEY=${BAIDU_OCR_API_KEY}
BAIDU_OCR_SECRET_KEY=${BAIDU_OCR_SECRET_KEY}

# ----------------------------------------
# 阿里云短信服务配置
# ----------------------------------------
SMS_ACCESS_KEY=${SMS_ACCESS_KEY}
SMS_SECRET_KEY=${SMS_SECRET_KEY}
SMS_SIGN_NAME=肾健康助手
SMS_TEMPLATE_CODE=${SMS_TEMPLATE_CODE}

# ----------------------------------------
# 阿里云 OSS 配置
# ----------------------------------------
OSS_ACCESS_KEY_ID=${OSS_ACCESS_KEY_ID}
OSS_ACCESS_KEY_SECRET=${OSS_ACCESS_KEY_SECRET}
OSS_BUCKET=health-monitoring-prod
OSS_REGION=oss-cn-hangzhou
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# ----------------------------------------
# 日志配置
# ----------------------------------------
LOG_LEVEL=warn

# ----------------------------------------
# Worker 配置
# ----------------------------------------
ENABLE_REMINDER_WORKER=true

# ----------------------------------------
# 前端配置 (构建时注入)
# ----------------------------------------
VITE_API_BASE_URL=/api
VITE_APP_NAME=肾健康助手
VITE_APP_VERSION=1.0.0
