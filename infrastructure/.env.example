# ============================================
# 环境变量示例文件
# ============================================
# 使用方法:
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 修改所有敏感配置值
# 3. 确保 .env 已添加到 .gitignore
# ============================================

# ----------------------------------------
# 基础配置
# ----------------------------------------
NODE_ENV=development
PORT=3000

# ----------------------------------------
# 数据库配置 (PostgreSQL)
# ----------------------------------------
POSTGRES_USER=health
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=health_monitoring
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# ----------------------------------------
# Redis 配置
# ----------------------------------------
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379

# ----------------------------------------
# JWT 配置
# ----------------------------------------
# JWT密钥 - 至少32位字符，生产环境请使用随机生成的强密码
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars-long
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ----------------------------------------
# 数据加密密钥
# ----------------------------------------
# 用于加密敏感医疗数据，必须32位字符
ENCRYPTION_KEY=your-encryption-key-32-chars-long

# ----------------------------------------
# 百度 OCR 配置
# ----------------------------------------
BAIDU_OCR_API_KEY=your_baidu_api_key
BAIDU_OCR_SECRET_KEY=your_baidu_secret_key

# ----------------------------------------
# 阿里云短信服务配置
# ----------------------------------------
SMS_ACCESS_KEY=your_aliyun_access_key
SMS_SECRET_KEY=your_aliyun_secret_key
SMS_SIGN_NAME=your_sms_sign_name
SMS_TEMPLATE_CODE=your_template_code

# ----------------------------------------
# 阿里云 OSS 配置
# ----------------------------------------
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_BUCKET=your-bucket-name
OSS_REGION=oss-cn-hangzhou
OSS_ENDPOINT=https://${OSS_REGION}.aliyuncs.com

# ----------------------------------------
# 日志配置
# ----------------------------------------
LOG_LEVEL=info
# 可选值: debug, info, warn, error

# ----------------------------------------
# Worker 配置
# ----------------------------------------
ENABLE_REMINDER_WORKER=true

# ----------------------------------------
# 前端配置
# ----------------------------------------
VITE_API_BASE_URL=/api
VITE_APP_NAME=肾健康助手
