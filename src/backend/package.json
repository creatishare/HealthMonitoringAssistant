    "lint": "eslint src --ext .ts",
    "test": "jest"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "bull": "^4.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
