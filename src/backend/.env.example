# 数据库配置
DATABASE_URL="postgresql://user:password@localhost:5432/health_db?schema=public"

# Redis配置
REDIS_URL="redis://localhost:6379"

# JWT配置
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="7d"

# 服务器配置
PORT=3001
NODE_ENV="development"

# OCR服务配置（百度AI）
BAIDU_OCR_APP_ID=""
BAIDU_OCR_API_KEY=""
BAIDU_OCR_SECRET_KEY=""

# 文件上传配置
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880

# 日志配置
LOG_LEVEL="info"
