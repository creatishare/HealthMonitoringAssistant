# 数据库配置
DATABASE_URL="postgresql://user:password@localhost:5432/health_db?schema=public"

# Redis配置
REDIS_URL="redis://localhost:6379"

# JWT配置
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="7d"

# 服务器配置
PORT=3001
NODE_ENV="development"

# OCR服务配置（百度AI）
BAIDU_OCR_APP_ID=""
BAIDU_OCR_API_KEY=""
BAIDU_OCR_SECRET_KEY=""

# 文件上传配置
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880

# 日志配置
LOG_LEVEL="info"

# 阿里云短信服务配置
SMS_ACCESS_KEY=""
SMS_SECRET_KEY=""
SMS_SIGN_NAME="肾健康助手"
SMS_TEMPLATE_CODE_VERIFICATION=""
SMS_TEMPLATE_CODE_REMINDER=""
SMS_TEMPLATE_CODE_MISS=""
SMS_TEMPLATE_CODE_ALERT=""

# Web Push配置（VAPID密钥）
# 生成命令: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"

